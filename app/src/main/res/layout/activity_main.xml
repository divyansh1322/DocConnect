<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/doc_background"
    tools:context=".MainActivity">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="56dp" />

    <com.google.android.material.bottomnavigation.BottomNavigationView
    android:id="@+id/bottom_navigation"
    android:layout_width="match_parent"
        android:layout_height="70dp"
        app:itemPaddingTop="6dp"
        app:itemPaddingBottom="8dp"
    android:layout_gravity="bottom"
    android:background="@color/doc_surface_input"

    app:itemIconTint="@color/bnv_tab_color"
    app:itemTextColor="@color/bnv_tab_color"
    app:labelVisibilityMode="labeled"
        app:itemIconSize="22dp"

        app:itemTextAppearanceActive="@style/NavTextSmall"
        app:itemTextAppearanceInactive="@style/NavTextSmall"
    app:menu="@menu/bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>