<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardBackgroundColor="@color/doc_surface"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeColor="#F2F4F7"
    app:strokeWidth="1.2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAvatar"
            android:layout_width="44dp"
            android:layout_height="44dp"
            app:cardBackgroundColor="#F0F7FF"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvInitials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/doc_primary"
                android:textSize="14sp"
                tools:text="JD" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/tvPatientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-black"
            android:maxLines="1"
            android:textColor="#1A1C1E"
            android:textSize="16sp"
            app:layout_constraintEnd_toStartOf="@+id/tvDate"
            app:layout_constraintStart_toEndOf="@id/cardAvatar"
            app:layout_constraintTop_toTopOf="@id/cardAvatar"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="#94A3B8"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/tvPatientName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvPatientName"
            tools:text="2 days ago" />

        <ImageView
            android:id="@+id/ivStar"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_star"
            app:layout_constraintStart_toStartOf="@id/tvPatientName"
            app:layout_constraintTop_toBottomOf="@id/tvPatientName"
            app:tint="#F59E0B" />

        <TextView
            android:id="@+id/tvRatings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:fontFamily="sans-serif-black"
            android:textColor="#1A1C1E"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/ivStar"
            app:layout_constraintStart_toEndOf="@id/ivStar"
            app:layout_constraintTop_toTopOf="@id/ivStar"
            tools:text="5.0" />

        <View
            android:id="@+id/vDivider"
            android:layout_width="1dp"
            android:layout_height="12dp"
            android:layout_marginStart="8dp"
            android:background="#E2E8F0"
            app:layout_constraintBottom_toBottomOf="@id/tvRatings"
            app:layout_constraintStart_toEndOf="@id/tvRatings"
            app:layout_constraintTop_toTopOf="@id/tvRatings" />

        <TextView
            android:id="@+id/tvVerified"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-black"
            android:text="Verified Patient"
            android:textColor="#059669"
            android:textSize="11sp"
            android:letterSpacing="0.02"
            app:layout_constraintBottom_toBottomOf="@id/vDivider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/vDivider"
            app:layout_constraintTop_toTopOf="@id/vDivider" />

        <TextView
            android:id="@+id/tvfeedback"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:fontFamily="sans-serif"
            android:lineSpacingExtra="5sp"
            android:textColor="#475569"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cardAvatar"
            tools:text="The doctor was extremely professional and took the time to explain everything clearly. Highly recommended for anyone seeking quality care." />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>