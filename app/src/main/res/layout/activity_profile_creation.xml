<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/doc_background"
    android:fitsSystemWindows="true"
    tools:context=".ProfileCreationActivity">

    <ImageView
        android:id="@+id/btnBack"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:contentDescription="Back"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/doc_text_primary" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Patient's Details"
        android:textColor="@color/doc_text_primary"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:padding="16dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/btnContinue"
        app:layout_constraintTop_toBottomOf="@id/btnBack">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                style="@style/DocLabelText"
                android:text="Full Name *" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutName"
                style="@style/DocInputBox"
                app:startIconDrawable="@drawable/ic_person">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etFullName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPersonName"
                    android:textColor="@color/doc_text_primary"
                    android:textColorHint="@color/doc_text_hint"/>
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/DocLabelText"
                android:text="Email *" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutEmail"
                style="@style/DocInputBox"
                app:startIconDrawable="@drawable/ic_email">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"
                    android:textColor="@color/doc_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/DocLabelText"
                android:text="Phone *" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutPhone"
                style="@style/DocInputBox"
                app:startIconDrawable="@drawable/ic_phone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPhone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="phone"
                    android:textColor="@color/doc_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/DocLabelText"
                android:text="Gender *" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutGender"
                style="@style/DocInputBox"
                app:endIconMode="dropdown_menu"
                app:startIconDrawable="@drawable/ic_gender">

                <AutoCompleteTextView
                    android:id="@+id/acGender"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"

                    android:inputType="none"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp"
                    android:textColor="@color/doc_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/DocLabelText"
                android:text="Age *" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutAge"
                style="@style/DocInputBox"
                app:startIconDrawable="@drawable/ic_calendar">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="number"
                    android:maxLength="3"
                    android:textColor="@color/doc_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                style="@style/DocLabelText"
                android:text="Visiting Purpose *" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/inputLayoutPurpose"
                style="@style/DocInputBox"
                android:layout_marginBottom="20dp"
                app:startIconDrawable="@drawable/ic_note">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etPurpose"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"

                    android:inputType="textMultiLine"
                    android:minLines="3"
                    android:textColor="@color/doc_text_primary" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </ScrollView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_margin="16dp"
        android:text="Continue"
        android:textSize="18sp"
        android:textAllCaps="false"
        android:backgroundTint="@color/doc_primary"
        app:cornerRadius="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>