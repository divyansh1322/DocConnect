<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingHorizontal="16dp"
    android:paddingVertical="4dp"
    android:clipToPadding="false"
    android:gravity="center_vertical">

    <TextView
        android:id="@+id/tvTimeLabel"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:text="09:00 AM"
        android:gravity="center"
        android:textColor="@color/doc_text_heading"
        android:textSize="10sp"
        android:letterSpacing="-0.02" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        app:cardCornerRadius="24dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/doc_surface"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingVertical="12dp">

            <View
                android:id="@+id/viewStatusIndicator"
                android:layout_width="6dp"
                android:layout_height="32dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_status_indicator_pill" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivPatientImage"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_doctor"
                app:shapeAppearanceOverlay="@style/CircleImage"
                app:strokeColor="@color/doc_surface_input"
                app:strokeWidth="1dp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="16dp"
                android:layout_marginStart="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_toStartOf="@id/ivChevron"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvPatientName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="Patient Name"
                        android:textColor="@color/doc_text_heading"
                        android:textSize="15sp"
                        android:fontFamily="sans-serif-black" />

                    <TextView
                        android:id="@+id/tvVisitDetails"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="24 Yrs • Male"
                        android:textColor="@color/doc_text_body"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"/>
                </LinearLayout>

                <ImageView
                    android:id="@+id/ivChevron"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_circle_action"
                    android:padding="6dp"
                    android:src="@drawable/ic_chevron_right"
                    app:tint="@color/brand_blue" />

            </RelativeLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>