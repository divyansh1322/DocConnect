<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="10dp"
    app:cardBackgroundColor="@color/doc_surface"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/doc_divider"
    app:strokeWidth="1.2dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/patientImg"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_placeholder"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:shapeAppearanceOverlay="@style/CircleImage"
            tools:src="@tools:sample/avatars" />

        <TextView
            android:id="@+id/tvstatusBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_scheduled"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.04"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:text="UPCOMING"
            android:textColor="@color/doc_primary"
            android:textSize="9sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/patientName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-black"
            android:maxLines="1"
            android:textColor="@color/doc_text_heading"
            android:textSize="17sp"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toStartOf="@id/tvstatusBadge"
            app:layout_constraintStart_toEndOf="@id/patientImg"
            app:layout_constraintTop_toTopOf="@id/patientImg"
            tools:text="David Miller" />

        <TextView
            android:id="@+id/patient_age"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_chip_age"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/doc_text_secondary"
            android:textSize="10sp"
            app:layout_constraintStart_toStartOf="@id/patientName"
            app:layout_constraintTop_toBottomOf="@id/patientName"
            tools:text="45 yrs" />

        <TextView
            android:id="@+id/patient_gender"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:background="@drawable/bg_chip_gender"
            android:fontFamily="sans-serif-medium"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textColor="@color/doc_primary"
            android:textSize="10sp"
            app:layout_constraintBottom_toBottomOf="@id/patient_age"
            app:layout_constraintStart_toEndOf="@id/patient_age"
            app:layout_constraintTop_toTopOf="@id/patient_age"
            tools:text="Male" />

        <View
            android:id="@+id/divider"
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/doc_divider"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/patientImg" />

        <ImageView
            android:id="@+id/ivDateIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginTop="12dp"
            android:padding="6dp"
            android:src="@drawable/ic_calendar"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:tint="@color/doc_primary" />

        <TextView
            android:id="@+id/consult_date"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/doc_text_heading"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/ivDateIcon"
            app:layout_constraintEnd_toStartOf="@+id/ivTimeIcon"
            app:layout_constraintStart_toEndOf="@id/ivDateIcon"
            app:layout_constraintTop_toTopOf="@id/ivDateIcon"
            tools:text="Feb 24, 2026" />

        <ImageView
            android:id="@+id/ivTimeIcon"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:padding="6dp"
            android:src="@drawable/ic_clock"
            app:layout_constraintBottom_toBottomOf="@id/ivDateIcon"
            app:layout_constraintEnd_toStartOf="@+id/consult_time"
            app:layout_constraintStart_toEndOf="@id/consult_date"
            app:layout_constraintTop_toTopOf="@id/ivDateIcon"
            app:tint="@color/doc_primary" />

        <TextView
            android:id="@+id/consult_time"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/doc_text_heading"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="@id/ivTimeIcon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/ivTimeIcon"
            app:layout_constraintTop_toTopOf="@id/ivTimeIcon"
            tools:text="12:15 PM" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_start"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="8dp"
            android:fontFamily="sans-serif-black"
            android:minHeight="48dp"
            android:text="Start Consultation"
            android:textAllCaps="false"
            android:textSize="13sp"
            app:cornerRadius="14dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/btnDetails"
            app:layout_constraintHorizontal_weight="1.3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ivDateIcon" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDetails"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-black"
            android:minHeight="48dp"
            android:text="Details"
            android:textAllCaps="false"
            android:textColor="@color/doc_text_body"
            android:textSize="13sp"
            app:cornerRadius="14dp"
            app:layout_constraintBottom_toBottomOf="@id/btn_start"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_weight="0.7"
            app:layout_constraintStart_toEndOf="@id/btn_start"
            app:layout_constraintTop_toTopOf="@id/btn_start" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>