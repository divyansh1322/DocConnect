<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/doc_background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:fitsSystemWindows="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="40dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/headerContainer"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:paddingHorizontal="8dp"
                app:layout_constraintTop_toTopOf="parent">

                <ImageButton
                    android:id="@+id/btnBack"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/ic_arrow_back"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="@color/doc_text_primary" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Clinic Details"
                    android:textColor="@color/doc_text_primary"
                    android:textSize="20sp"
                    android:fontFamily="sans-serif-black"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@+id/header_spacer"
                    app:layout_constraintStart_toEndOf="@id/btnBack"
                    app:layout_constraintTop_toTopOf="parent" />

                <View
                    android:id="@+id/header_spacer"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="@color/doc_surface"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp"
                app:layout_constraintTop_toBottomOf="@id/headerContainer">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="20dp">

                    <TextView
                        android:id="@+id/tvTag"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_blue_light"
                        android:paddingHorizontal="12dp"
                        android:paddingVertical="6dp"
                        android:text="PRIMARY CLINIC"
                        android:textColor="@color/doc_primary"
                        android:textSize="10sp"
                        android:fontFamily="sans-serif-bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_verified"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="@color/doc_primary" />

                    <TextView
                        android:id="@+id/tvClinicName"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="My Clinic Name"
                        android:textColor="@color/doc_text_heading"
                        android:textSize="22sp"
                        android:fontFamily="sans-serif-black"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvTag" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Registered Clinic Identity"
                        android:textColor="@color/doc_text_secondary"
                        android:textSize="12sp"
                        android:fontFamily="sans-serif-medium"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvClinicName" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/layoutPhotosHeader"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/cardHeader">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="CLINIC PHOTOS"
                    android:textColor="@color/doc_text_hint"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif-bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scroll to view"
                    android:textColor="@color/doc_text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <HorizontalScrollView
                android:id="@+id/photosContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:clipToPadding="false"
                android:paddingHorizontal="20dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/layoutPhotosHeader">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/btnAddPhoto"
                        android:layout_width="120dp"
                        android:layout_height="100dp"
                        android:layout_marginEnd="12dp"
                        app:cardBackgroundColor="@color/doc_surface_input"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeColor="@color/doc_divider"
                        app:strokeWidth="1dp">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_camera_alt"
                                app:tint="@color/doc_primary" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:text="Add Photo"
                                android:textColor="@color/doc_primary"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif-bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvClinicImages"
                        android:layout_width="wrap_content"
                        android:layout_height="100dp"
                        android:orientation="horizontal"
                        tools:listitem="@layout/item_clinic_image" />
                </LinearLayout>
            </HorizontalScrollView>

            <TextView
                android:id="@+id/tvFacilitiesLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="28dp"
                android:text="FACILITIES"
                android:textColor="@color/doc_text_hint"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/photosContainer" />

            <LinearLayout
                android:id="@+id/layoutFacilities"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:paddingHorizontal="10dp"
                android:weightSum="3"
                app:layout_constraintTop_toBottomOf="@id/tvFacilitiesLabel">

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <com.google.android.material.card.MaterialCardView android:layout_width="56dp" android:layout_height="56dp" app:cardBackgroundColor="@color/doc_surface" app:cardCornerRadius="28dp" app:cardElevation="0dp" app:strokeColor="@color/doc_divider" app:strokeWidth="1dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:src="@drawable/ic_local_parking" app:tint="@color/doc_primary" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Parking" android:textColor="@color/doc_text_body" android:textSize="12sp" android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <com.google.android.material.card.MaterialCardView android:layout_width="56dp" android:layout_height="56dp" app:cardBackgroundColor="@color/doc_surface" app:cardCornerRadius="28dp" app:cardElevation="0dp" app:strokeColor="@color/doc_divider" app:strokeWidth="1dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:src="@drawable/ic_medication" app:tint="@color/doc_primary" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Pharmacy" android:textColor="@color/doc_text_body" android:textSize="12sp" android:fontFamily="sans-serif-medium" />
                </LinearLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:orientation="vertical">
                    <com.google.android.material.card.MaterialCardView android:layout_width="56dp" android:layout_height="56dp" app:cardBackgroundColor="@color/doc_surface" app:cardCornerRadius="28dp" app:cardElevation="0dp" app:strokeColor="@color/doc_divider" app:strokeWidth="1dp">
                        <ImageView android:layout_width="22dp" android:layout_height="22dp" android:layout_gravity="center" android:src="@drawable/ic_science" app:tint="@color/doc_primary" />
                    </com.google.android.material.card.MaterialCardView>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Lab" android:textColor="@color/doc_text_body" android:textSize="12sp" android:fontFamily="sans-serif-medium" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvContactLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="32dp"
                android:text="LOCATION ADDRESS"
                android:textColor="@color/doc_text_hint"
                android:textSize="11sp"
                android:fontFamily="sans-serif-bold"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/layoutFacilities" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilAddress"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="12dp"
                app:boxCornerRadiusBottomEnd="16dp"
                app:boxCornerRadiusBottomStart="16dp"
                app:boxCornerRadiusTopEnd="16dp"
                app:boxCornerRadiusTopStart="16dp"
                app:layout_constraintTop_toBottomOf="@id/tvContactLabel"
                app:startIconDrawable="@drawable/ic_location"
                app:startIconTint="@color/doc_primary"
                app:endIconMode="custom"
                app:endIconDrawable="@drawable/ic_my_location"
                app:endIconTint="@color/doc_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Full Clinic Address..."
                    android:inputType="textPostalAddress|textMultiLine"
                    android:minLines="1"
                    android:maxLines="3"
                    android:textColor="@color/doc_text_heading"
                    android:textSize="15sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="32dp"
                android:text="Save Clinic Changes"
                android:textAllCaps="false"
                android:textSize="16sp"
                android:fontFamily="sans-serif-black"
                app:backgroundTint="@color/doc_primary"
                app:cornerRadius="18dp"
                app:layout_constraintTop_toBottomOf="@id/tilAddress"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>