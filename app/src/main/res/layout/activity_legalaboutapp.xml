<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/doc_background">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fitsSystemWindows="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/headerLayout"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:paddingHorizontal="12dp"
            app:layout_constraintTop_toTopOf="parent">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/ic_arrow_back"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/doc_text_heading" />

            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-black"
                android:gravity="center"
                android:text="Legal &amp; About"
                android:textColor="@color/doc_text_primary"
                android:textSize="20sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@+id/header_spacer"
                app:layout_constraintStart_toEndOf="@id/btnBack"
                app:layout_constraintTop_toTopOf="parent" />

            <View
                android:id="@+id/header_spacer"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:clipToPadding="false"
            android:fillViewport="true"
            app:layout_constraintBottom_toTopOf="@+id/footerLayout"
            app:layout_constraintTop_toBottomOf="@id/headerLayout">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical"
                android:paddingHorizontal="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="32dp">

                <ImageView
                    android:id="@+id/imgLogo"
                    android:layout_width="86dp"
                    android:layout_height="86dp"
                    android:src="@drawable/ic_shield"
                    />

                <TextView
                    android:id="@+id/tvAppName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:fontFamily="sans-serif-black"
                    android:text="DocConnect"
                    android:textColor="@color/doc_text_heading"
                    android:textSize="22sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_pill_gray"
                    android:fontFamily="sans-serif-black"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="6dp"
                    android:text="Version 1.0.2 (Build 45)"
                    android:textColor="@color/doc_text_secondary"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvListHeader"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="12dp"
                    android:fontFamily="sans-serif-black"
                    android:letterSpacing="0.05"
                    android:text="LEGAL INFORMATION"
                    android:textColor="@color/doc_text_hint"
                    android:textSize="11sp" />

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardBackgroundColor="@color/doc_surface"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/divider_gray"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <RelativeLayout
                            android:id="@+id/btn_terms"
                            android:layout_width="match_parent"
                            android:layout_height="72dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="16dp">
                            <ImageView android:id="@+id/icon1" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="@drawable/bg_icon_square" android:backgroundTint="@color/doc_primary_light" android:padding="10dp" android:src="@drawable/ic_description" app:tint="@color/doc_primary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="16dp" android:layout_toEndOf="@id/icon1" android:fontFamily="sans-serif-medium" android:text="Terms &amp; Conditions" android:textColor="@color/doc_text_heading" android:textSize="16sp" />
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_chevron_right" app:tint="@color/doc_text_hint" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="@color/divider_gray" />

                        <RelativeLayout
                            android:id="@+id/btn_privacy"
                            android:layout_width="match_parent"
                            android:layout_height="72dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="16dp">
                            <ImageView android:id="@+id/icon2" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="@drawable/bg_icon_square" android:backgroundTint="@color/doc_primary_light" android:padding="10dp" android:src="@drawable/ic_lock" app:tint="@color/doc_primary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="16dp" android:layout_toEndOf="@id/icon2" android:fontFamily="sans-serif-medium" android:text="Privacy Policy" android:textColor="@color/doc_text_heading" android:textSize="16sp" />
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_chevron_right" app:tint="@color/doc_text_hint" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="@color/divider_gray" />

                        <RelativeLayout
                            android:id="@+id/btn_data"
                            android:layout_width="match_parent"
                            android:layout_height="72dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="16dp">
                            <ImageView android:id="@+id/icon3" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="@drawable/bg_icon_square" android:backgroundTint="@color/doc_primary_light" android:padding="10dp" android:src="@drawable/ic_verified_user" app:tint="@color/doc_primary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="16dp" android:layout_toEndOf="@id/icon3" android:fontFamily="sans-serif-medium" android:text="Data Usage &amp; Protection" android:textColor="@color/doc_text_heading" android:textSize="16sp" />
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_chevron_right" app:tint="@color/doc_text_hint" />
                        </RelativeLayout>

                        <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginHorizontal="16dp" android:background="@color/divider_gray" />

                        <RelativeLayout
                            android:id="@+id/btn_about"
                            android:layout_width="match_parent"
                            android:layout_height="72dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingHorizontal="16dp">
                            <ImageView android:id="@+id/icon4" android:layout_width="40dp" android:layout_height="40dp" android:layout_centerVertical="true" android:background="@drawable/bg_icon_square" android:backgroundTint="@color/doc_primary_light" android:padding="10dp" android:src="@drawable/ic_info" app:tint="@color/doc_primary" />
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_centerVertical="true" android:layout_marginStart="16dp" android:layout_toEndOf="@id/icon4" android:fontFamily="sans-serif-medium" android:text="About Us" android:textColor="@color/doc_text_heading" android:textSize="16sp" />
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_alignParentEnd="true" android:layout_centerVertical="true" android:src="@drawable/ic_chevron_right" app:tint="@color/doc_text_hint" />
                        </RelativeLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <LinearLayout
            android:id="@+id/footerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingBottom="24dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:text="© 2026 DocConnect Inc."
                android:textColor="@color/doc_text_secondary"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="All rights reserved."
                android:textColor="@color/doc_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>