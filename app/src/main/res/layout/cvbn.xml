<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="#E2E8F0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_time_badge"
            android:backgroundTint="#EFF6FF"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp">

            <TextView
                android:id="@+id/tvAppointmentTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10:30 - 10:50 AM"
                android:textColor="@color/doc_primary"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="-0.01"/>
        </LinearLayout>

        <View
            android:layout_width="1.5dp"
            android:layout_height="36dp"
            android:background="#CBD5E1"
            android:layout_marginHorizontal="16dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvPatientName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Priya Singh"
                android:textSize="17sp"
                android:fontFamily="sans-serif-black"
                android:textColor="#1E293B"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvGender"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:background="@color/doc_primary"
                    android:fontFamily="sans-serif-medium"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"
                    android:text="Female"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/tvAge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="34 Yrs"
                    android:textSize="11sp"
                    android:textColor="#64748B"
                    android:background="#F1F5F9"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"
                    android:fontFamily="sans-serif-medium"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WAITING"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#B45309"
            android:background="@drawable/bg_rounded_status_waiting"
            android:paddingHorizontal="12dp"
            android:paddingVertical="6dp"/>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>