<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/doc_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="30dp"> <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_centerVertical="true"
            android:padding="2dp"
            android:src="@drawable/ic_arrow_back"
            app:tint="@color/doc_text_heading"
            android:contentDescription="Back" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="23dp"
                android:layout_height="27dp"
                android:contentDescription="Logo"
                android:src="@drawable/ic_shield"
                />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-black"
                android:text="DocConnect"
                android:textColor="@color/doc_text_heading"
                android:textSize="20sp" />
        </LinearLayout>
    </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="Doctor Registration"
            android:textColor="@color/doc_text_heading"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="40dp"
            android:alpha="0.8"
            android:text="Create your professional account. You will complete your profile details in the next step."
            android:textColor="@color/doc_text_secondary"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Full Name"
            android:textAllCaps="true"
            android:textColor="@color/doc_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etFullName"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_input_field"
            android:hint="Dr. Jane Doe"
            android:inputType="textPersonName|textCapWords"
            android:paddingHorizontal="20dp"
            android:textColor="@color/doc_text_heading"
            android:textColorHint="@color/doc_text_hint"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Email Address"
            android:textAllCaps="true"
            android:textColor="@color/doc_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_input_field"
            android:hint="doctor@clinic.com"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="20dp"
            android:textColor="@color/doc_text_heading"
            android:textColorHint="@color/doc_text_hint"
            android:textSize="15sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Password"
            android:textAllCaps="true"
            android:textColor="@color/doc_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp">

            <EditText
                android:id="@+id/etPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_input_field"
                android:hint="••••••••••••"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="56dp"
                android:textColor="@color/doc_text_heading"
                android:textColorHint="@color/doc_text_hint"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/ivTogglePassword"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye_on"
                app:tint="@color/doc_text_hint"
                android:contentDescription="Toggle Password" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            android:text="Confirm Password"
            android:textAllCaps="true"
            android:textColor="@color/doc_text_secondary"
            android:textSize="12sp"
            android:letterSpacing="0.05"
            android:textStyle="bold" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="40dp">

            <EditText
                android:id="@+id/etConfirmPassword"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="@drawable/bg_input_field"
                android:hint="••••••••••••"
                android:inputType="textPassword"
                android:paddingStart="20dp"
                android:paddingEnd="56dp"
                android:textColor="@color/doc_text_heading"
                android:textColorHint="@color/doc_text_hint"
                android:textSize="15sp" />

            <ImageView
                android:id="@+id/ivToggleConfirmPassword"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:layout_marginEnd="16dp"
                android:src="@drawable/ic_eye_on"
                app:tint="@color/doc_text_hint"
                android:contentDescription="Toggle Password" />
        </RelativeLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSignUp"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            app:backgroundTint="@color/doc_primary"
            android:text="Create Account"
            android:textAllCaps="false"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            app:cornerRadius="16dp"
            app:elevation="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="24dp"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Already have an account? "
                android:textColor="@color/doc_text_secondary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvLogin"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Log In"
                android:textColor="@color/doc_primary"
                android:textStyle="bold"
                android:padding="8dp"
                android:textSize="15sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>