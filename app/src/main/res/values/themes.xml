<resources>
    <style name="Theme.DocConnect" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/doc_primary</item>
        <item name="android:statusBarColor">@color/doc_background</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowBackground">@color/doc_background</item>


    </style>


    <style name="RoundedAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.DocConnect.Dialog</item>
        <item name="colorSurface">@color/doc_surface</item>
        <item name="colorOnSurface">@color/doc_text_primary</item>
        <item name="colorPrimary">@color/doc_primary</item>
    </style>

    <style name="ShapeAppearance.DocConnect.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <style name="NavTextSmall">
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

</resources>